# === LLM / Anthropic ===
# Add your real API key in .env (never commit real keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# === Runtime flags ===
# USE_LLM: enable LLM calls when run_report=True
USE_LLM=false
# DRY_RUN: if true, skip LLM calls and generate placeholder explanations
DRY_RUN=true
